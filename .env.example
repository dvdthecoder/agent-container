# ── Modal ───────────────────────────────────────────────────────────────────────
# Both the agent sandbox AND the model run on Modal.
# Get your token at https://modal.com/settings/tokens
MODAL_TOKEN_ID=ak-...
MODAL_TOKEN_SECRET=as-...

# ── Model endpoint ──────────────────────────────────────────────────────────────
# Step 1 — deploy your model on Modal GPU (do this once):
#
#   modal deploy modal/serve.py                       # Qwen3-Coder 8B  — A10G       (test/cheap)
#   SERVE_PROFILE=prod    modal deploy modal/serve.py  # Qwen3-Coder 80B — 2×A100 80G (production)
#   SERVE_PROFILE=minimax modal deploy modal/serve.py  # MiniMax M2.5    — 8×A100 80G (best quality)
#
# Step 2 — Modal prints the endpoint URL after deploy. Paste it below:
OPENAI_BASE_URL=https://your-org--agent-container-serve-serve.modal.run
OPENAI_API_KEY=modal
OPENCODE_MODEL=qwen2.5-coder   # match the SERVED_MODEL_NAME in modal/serve.py

# ── HuggingFace ────────────────────────────────────────────────────────────────
# Required for modal/serve.py to download model weights (read access is enough)
# Get your token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# ── Git provider ───────────────────────────────────────────────────────────────
# GitHub fine-grained token — needs: Contents (read) + Pull Requests (read/write)
GITHUB_TOKEN=ghp_...

# GitLab — enterprise / self-hosted (leave blank if using GitHub)
# GITLAB_TOKEN=glpat-...
# GITLAB_URL=https://gitlab.yourcompany.com

# ── Dashboard ──────────────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
