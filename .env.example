# ── Modal ───────────────────────────────────────────────────────────────────────
# Both the agent sandbox AND the model run on Modal.
# Get your token at https://modal.com/settings/tokens
MODAL_TOKEN_ID=ak-...
MODAL_TOKEN_SECRET=as-...

# ── Model endpoint ──────────────────────────────────────────────────────────────
# Step 1 — deploy your model:
#
#   make deploy                          # default: Qwen2.5-Coder 32B · A100 80GB
#   make deploy MODEL=qwen3-8b           # Qwen3 8B · A10G (fast/cheap)
#   make deploy MODEL=qwen3-30b          # Qwen3 30B-A3B · A100 40GB
#   make deploy MODEL=gemma4-12b         # Gemma 4 12B · A10G
#
# App names always include the model slug, so you can run multiple models
# simultaneously. The URL format is:
#   https://{your-org}--agent-container-serve-{model-slug}-serve.modal.run
#
# make deploy writes the correct URL to OPENAI_BASE_URL in this file automatically.
# You can also paste it manually after `modal deploy modal/serve.py` prints it.
OPENAI_BASE_URL=https://your-org--agent-container-serve-qwen2-5-coder-32b-serve.modal.run
OPENAI_API_KEY=modal
OPENCODE_MODEL=qwen2.5-coder-32b   # must match the served_name in serve.py _PROD_MODELS

# ── HuggingFace ────────────────────────────────────────────────────────────────
# Required for modal/serve.py to download model weights (read access is enough)
# Get your token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# ── Git provider ───────────────────────────────────────────────────────────────
# GitHub fine-grained token — needs: Contents (read) + Pull Requests (read/write)
GITHUB_TOKEN=ghp_...

# GitLab — enterprise / self-hosted (leave blank if using GitHub)
# GITLAB_TOKEN=glpat-...
# GITLAB_URL=https://gitlab.yourcompany.com

# ── Dashboard ──────────────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
